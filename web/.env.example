# Neura Web Frontend — environment variables
# Copy to .env.local and adjust for your environment

# Backend API base URL (empty = same origin via Vite proxy)
VITE_API_URL=

# WebSocket URL (empty = auto-detect from window.location)
VITE_WS_URL=

# Production values:
# VITE_API_URL=https://api.your-domain.com
# VITE_WS_URL=wss://api.your-domain.com
