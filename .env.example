# ============================================================
# Neura Platform v2 — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# All variables marked [REQUIRED] must be set before start.
# Variables marked [OPTIONAL] have working defaults.
# ============================================================

# --- Database (PostgreSQL + pgvector) -----------------------
# [REQUIRED] Password for the 'neura' database user
DB_PASSWORD=changeme_secure_password

# [REQUIRED] Full connection string (uses DB_PASSWORD above)
DATABASE_URL=postgresql://neura:${DB_PASSWORD}@localhost:5432/neura

# --- Cache (Redis) ------------------------------------------
# [REQUIRED] Redis connection URL (with password if set)
REDIS_URL=redis://:your_redis_password@localhost:6379/0

# --- Web Platform -------------------------------------------
# [OPTIONAL] Port for FastAPI backend (default: 8080)
WEB_PORT=8080

# [REQUIRED] Secret key for JWT token signing (generate with: openssl rand -hex 32)
JWT_SECRET=

# --- Server Identification ----------------------------------
# [OPTIONAL] Server name shown in monitoring notifications
SERVER_NAME=MyServer

# --- Telegram Bot Tokens ------------------------------------
# Each capsule needs its own bot token from @BotFather.
# Variable name pattern: <CAPSULE_NAME>_BOT_TOKEN
# Add as many as you need. Reference them in capsule YAML configs as ${VAR_NAME}.
#
# Examples:
# MY_BOT_TOKEN=123456:ABCdefGHIjklMNO
# CLIENT_BOT_TOKEN=789012:PQRstuVWXyz

# --- Telethon (Telegram Userbot) ----------------------------
# [OPTIONAL] Required only if capsules use userbot features
# Get from https://my.telegram.org/apps
TELETHON_API_ID=
TELETHON_API_HASH=

# --- AI Engines (at least one required) ---------------------
# Claude is the primary engine (via claude CLI, no API key needed here).
# Below are optional fallback engines:

# [OPTIONAL] OpenRouter API key for fallback engine
OPENROUTER_API_KEY=

# [OPTIONAL] YandexGPT API key + folder ID
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# --- External Services (all optional) -----------------------
# Speech-to-text (Deepgram — recommended for voice messages)
DEEPGRAM_API_KEY=

# Image generation (GRSAI)
GRSAI_API_KEY=

# Web scraping (Firecrawl)
FIRECRAWL_API_KEY=

# --- HuggingFace (for local embedding models) ---------------
# [RECOMMENDED] Keep offline mode ON — models are cached locally
# Prevents hangs on network checks during vector indexing
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1
HF_HUB_DISABLE_IMPLICIT_TOKEN=1

# --- Browser Automation (optional) --------------------------
# Path to Chromium binary for Playwright
# CHROME_PATH=/usr/bin/chromium-browser
